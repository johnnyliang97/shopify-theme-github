      "settings": {
        "custom_liquid": "{%- assign banner_id = \"promo-banner-\" | append: section.id | default: \"global\" -%}\n\n<div id=\"{{ banner_id }}\" class=\"promo-banner\">\n  <span class=\"promo-banner__text\">\n    Please note that customs duties and import taxes charged by the destination country are payable by the purchaser. Email customercare@lestyle.com.au if you have any questions.\n  </span>\n  <button id=\"{{ banner_id }}__close\" class=\"promo-banner__close\" aria-label=\"Dismiss this message\" title=\"Dismiss\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n      <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n    </svg>\n  </button>\n</div>\n\n<style>\n  .promo-banner {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 12px 20px;\n    margin: 12px 0; /* Updated margin top/bottom to 12px */\n    background-color: #f8f2e9; /* Light tan to align with #c19967 */\n    color: #5c4730; /* Darker brown for text contrast */\n    border-radius: 8px; /* Corner radius */\n    font: 400 15px/1.4 -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Arial, sans-serif;\n  }\n  .promo-banner__close {\n    background: none;\n    border: none;\n    padding: 0;\n    margin-left: 16px;\n    cursor: pointer;\n    line-height: 0; /* Ensures the icon aligns well */\n    opacity: 0.6;\n    transition: opacity 0.2s ease-in-out;\n  }\n  .promo-banner__close:hover {\n    opacity: 1;\n  }\n  .promo-banner__close svg {\n    color: #5c4730; /* Updated icon color */\n    display: block;\n  }\n</style>\n\n<script>\n(function() {\n  const bannerId = '{{ banner_id }}';\n  const closeButtonId = bannerId + '__close';\n  const storageKey = 'promoBannerClosed_' + bannerId;\n\n  const banner = document.getElementById(bannerId);\n  const closeButton = document.getElementById(closeButtonId);\n\n  if (!banner || !closeButton) {\n    return;\n  }\n\n  // Check if the banner was already closed during this session\n  if (sessionStorage.getItem(storageKey) === 'true') {\n    banner.style.display = 'none';\n    return;\n  }\n\n  // Listen for a click on the close button\n  closeButton.addEventListener('click', function() {\n    banner.style.display = 'none';\n    \n    // Remember the closed state for this session only\n    try {\n      sessionStorage.setItem(storageKey, 'true');\n    } catch (e) {\n      console.error('sessionStorage is unavailable or full:', e);\n    }\n  });\n})();\n</script>",
        "custom_class": "container-fluid"
